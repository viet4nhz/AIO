-- Classify
local function isEnt(m)
    if not(m and m:IsA("Model")) or isPC(m) then return false end
    if m:FindFirstChildOfClass("Humanoid") or m:FindFirstChildOfClass("HumanoidDescription") then return true end
    for _,a in ipairs({"Health","HP","MaxHealth","MaxHP"}) do if m:GetAttribute(a) then return true end end
    local hv=m:FindFirstChild("Health") or m:FindFirstChild("HP");if hv and (hv:IsA("NumberValue") or hv:IsA("IntValue")) then return true end
    for _,ch in ipairs(m:GetDescendants()) do if ch:IsA("Script") then local n=ch.Name:lower();if n:find("ai") or n:find("npc") or n:find("enemy") or n:find("mob") then return true end end end
    for _,tag in ipairs(CS:GetTags(m)) do local tl=tag:lower();if tl:find("npc") or tl:find("enemy") or tl:find("mob") or tl:find("entity") then return true end end
    return false
end
local BL={"wall","floor","ceiling","ground","terrain","baseplate","road","path","tree","bush","grass","rock","stone","building","structure","barrier","fence","platform","stairs","stair","ramp","step","ledge","pillar","column","water","lava","sky","void","invisible","decor","window","glass","roof","tile","plank","board","brick","spawn","prop","ambient"}
local function isObj(i)
    if not(i and i.Parent) then return nil end
    local low=i.Name:lower();for _,k in ipairs(BL) do if low:find(k,1,true) then return nil end end
    local part=(i:IsA("BasePart") and not i:IsA("Terrain") and i) or (i:IsA("Model") and (i.PrimaryPart or i:FindFirstChildWhichIsA("BasePart")));if not part then return nil end
    for _,p in ipairs(PL:GetPlayers()) do if p.Character and (p.Character==i or part:IsDescendantOf(p.Character)) then return nil end end
    local pm=i:IsA("Model") and i or (i.Parent and i.Parent:IsA("Model") and i.Parent or nil);if pm and isEnt(pm) then return nil end
    local pp=i:FindFirstChild("ProximityPrompt",true);if pp then return pp.ActionText~="" and pp.ActionText or "Interact" end
    if i:FindFirstChild("ClickDetector",true) then return "Click" end
    for _,tag in ipairs(C.objTags) do if CS:HasTag(i,tag) then return tag end end
    for _,a in ipairs({"Interactable","CanPickup","IsItem","ItemType","CanCollect","Lootable"}) do local v=i:GetAttribute(a);if v then return tostring(v) end end
    for _,ch in ipairs(i:GetDescendants()) do if ch:IsA("Script") or ch:IsA("LocalScript") then local n=ch.Name:lower();if n:find("interact") or n:find("pickup") or n:find("item") or n:find("loot") then return "Script" end end end
    if math.max(part.Size.X,part.Size.Y,part.Size.Z)<=12 and part.Anchored then local pn=(i.Parent and i.Parent.Name:lower()) or "";if not(pn:find("map") or pn:find("world") or pn:find("environment") or pn:find("terrain")) then return "Object" end end
    return nil
end
