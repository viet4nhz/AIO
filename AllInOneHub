local function makeFovCircle()
    if fovSG then fovSG:Destroy();fovSG=nil end
    if not C.aimOn then return end
    fovSG=Instance.new("ScreenGui",LP.PlayerGui);fovSG.Name="ESP_FOV";fovSG.ResetOnSpawn=false;fovSG.IgnoreGuiInset=true;fovSG.DisplayOrder=99
    local sz=C.aimFov*4
    local f=Instance.new("Frame",fovSG);f.Size=UDim2.new(0,sz,0,sz);f.AnchorPoint=Vector2.new(.5,.5);f.Position=UDim2.new(.5,0,.5,0);f.BackgroundTransparency=1;f.BorderSizePixel=0
