    local st=Instance.new("UIStroke",f);st.Color=Color3.fromRGB(255,255,255);st.Thickness=1.2;st.Transparency=0.4
    fovSG._frame=f
end

local function updAim(dt)
    if not C.aimOn then return end
    local vp=Camera.ViewportSize;local center=Vector2.new(vp.X/2,vp.Y/2)
    local fovPx=C.aimFov*2
    local best,bestD=nil,math.huge
    local function check(hrp)
        local sp,vis=Camera:WorldToScreenPoint(hrp.Position)
        if not vis then return end
        local sd=(Vector2.new(sp.X,sp.Y)-center).Magnitude
        if sd<fovPx and sd<bestD then bestD=sd;best=hrp end
    end
    if C.aimPlayer then
        for _,pl in ipairs(PL:GetPlayers()) do
            if pl==LP then continue end
            local ch=pl.Character;local hrp=ch and ch:FindFirstChild("HumanoidRootPart");local hum=ch and ch:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health>0 then check(hrp) end
        end
    end
    if C.aimEntity then
        for inst,v in pairs(eC2) do
            if not v or not inst.Parent then continue end
            local p=inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart");if p then check(p) end
        end
    end
    if best then
        local t=1-math.pow(C.aimSmooth/100,dt*60)  -- smoothness: 1=snap, 100=very slow
        local cf=Camera.CFrame
        local dir=(best.Position-cf.Position).Unit
        local newCF=CFrame.new(cf.Position,cf.Position+dir)
        Camera.CFrame=cf:Lerp(newCF,math.clamp(t,0.01,1))
    end
end

