    mkToggle(aimPage,"Aim Assist  [G]",function()return C.aimOn     end,function(v)C.aimOn=v;     makeFovCircle() end)
    mkToggle(aimPage,"Aim Player",     function()return C.aimPlayer end,function(v)C.aimPlayer=v end)
    mkToggle(aimPage,"Aim Entity",     function()return C.aimEntity end,function(v)C.aimEntity=v end)
    mkSlider(aimPage,"FOV",            function()return C.aimFov    end,function(v)C.aimFov=v    end,1,100,function(v)
        if fovSG and fovSG._frame then local sz=v*4;fovSG._frame.Size=UDim2.new(0,sz,0,sz) end
    end)
    mkSlider(aimPage,"Smoothness",     function()return C.aimSmooth end,function(v)C.aimSmooth=v end,1,100)

    -- Bottom bar
    local bot=Instance.new("Frame",panel);bot.Size=UDim2.new(1,0,0,1);bot.Position=UDim2.new(0,0,0,H-1);bot.BackgroundColor3=COL.div;bot.BorderSizePixel=0

    -- Mobile FAB
    if mob then
        local fsg=Instance.new("ScreenGui",LP.PlayerGui);fsg.Name="ESP_FAB";fsg.ResetOnSpawn=false;fsg.IgnoreGuiInset=true;fsg.DisplayOrder=101
        local FAB=Instance.new("TextButton",fsg);FAB.Size=UDim2.new(0,64,0,64);FAB.Position=UDim2.new(0,14,1,-82);FAB.BackgroundColor3=COL.bg;FAB.BorderSizePixel=0;FAB.AutoButtonColor=false
        Instance.new("UICorner",FAB).CornerRadius=UDim.new(0,14)
        local fs=Instance.new("UIStroke",FAB);fs.Color=COL.div;fs.Thickness=1.5
        local fl=Instance.new("TextLabel",FAB);fl.Size=UDim2.new(1,0,0,16);fl.Position=UDim2.new(0,0,1,-18);fl.BackgroundTransparency=1;fl.TextColor3=COL.txt;fl.Font=Enum.Font.GothamBold;fl.TextSize=11;fl.Text="Menu"
        local function mkLn(y) local l=Instance.new("Frame",FAB);l.Size=UDim2.new(0,28,0,2);l.Position=UDim2.new(0.5,-14,0,y);l.BackgroundColor3=COL.txt;l.BorderSizePixel=0;Instance.new("UICorner",l).CornerRadius=UDim.new(1,0) end
        mkLn(16);mkLn(23);mkLn(30)
        local aInp,fPos,tPos=nil,nil,nil
        FAB.InputBegan:Connect(function(inp) if inp.UserInputType~=Enum.UserInputType.Touch then return end;aInp=inp;fPos=FAB.Position;tPos=Vector2.new(inp.Position.X,inp.Position.Y) end)
        FAB.InputChanged:Connect(function(inp) if inp~=aInp then return end;FAB.Position=UDim2.new(fPos.X.Scale,fPos.X.Offset+(inp.Position.X-tPos.X),fPos.Y.Scale,fPos.Y.Offset+(inp.Position.Y-tPos.Y)) end)
        FAB.InputEnded:Connect(function(inp)
            if inp~=aInp then return end
            if math.abs(inp.Position.X-tPos.X)<10 and math.abs(inp.Position.Y-tPos.Y)<10 then
                local open=not panel.Visible;panel.Visible=open
                TS:Create(FAB,TweenInfo.new(.12),{BackgroundColor3=open and COL.pg or COL.bg}):Play()
                fs.Color=open and COL.sub or COL.div
            end
            aInp=nil
        end)
    end

    UIS.InputBegan:Connect(function(inp,gpe)
        if gpe then return end;local k=inp.KeyCode
        if     k==Enum.KeyCode.Z then C.on=not C.on;      if not C.on then clrAll() end
        elseif k==Enum.KeyCode.X then C.player=not C.player
        elseif k==Enum.KeyCode.C then C.entity=not C.entity
        elseif k==Enum.KeyCode.V then C.object=not C.object
        elseif k==Enum.KeyCode.B then C.info=not C.info;   if not C.info   then clrBB() end
        elseif k==Enum.KeyCode.N then C.hitbox=not C.hitbox;if not C.hitbox then clrHB() end
        elseif k==Enum.KeyCode.G then C.aimOn=not C.aimOn; makeFovCircle()
        end
    end)
end

