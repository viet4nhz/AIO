local function updAim(dt)
    if not C.aimOn then return end
    local vp=Camera.ViewportSize;local center=Vector2.new(vp.X/2,vp.Y/2)
    local fovPx=C.aimFov*2;local best,bestD=nil,math.huge
    local function check(p)
        local sp,vis=Camera:WorldToScreenPoint(p.Position)
        if not vis then return end
        local sd=(Vector2.new(sp.X,sp.Y)-center).Magnitude
        if sd<fovPx and sd<bestD then bestD=sd;best=p end
    end
    if C.aimPlayer then
        for _,pl in ipairs(PL:GetPlayers()) do
            if pl==LP then continue end
            local ch=pl.Character;local hrp=ch and ch:FindFirstChild("HumanoidRootPart");local hum=ch and ch:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health>0 then check(hrp) end
        end
    end
    if C.aimEntity then
        for inst,v in pairs(eC2) do
            if not v or not inst.Parent then continue end
            local p=inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart");if p then check(p) end
        end
    end
    if best then
        local t=1-math.pow(math.clamp(C.aimSmooth/100,0.01,0.99),dt*60)
        local cf=Camera.CFrame;local dir=(best.Position-cf.Position).Unit
        Camera.CFrame=cf:Lerp(CFrame.new(cf.Position,cf.Position+dir),math.clamp(t,0.01,1))
    end
end

-- Commands
local cmdConns={}
local function stopCmd(name) if cmdConns[name] then cmdConns[name]:Disconnect();cmdConns[name]=nil end end
local function getHum() local ch=LP.Character;return ch and ch:FindFirstChildOfClass("Humanoid") end
