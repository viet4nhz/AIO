local noclipOn=false
local flyOn=false;local flySpeed=50;local flyConn=nil

local function setNoclip(on)
    noclipOn=on
    stopCmd("noclip")
    if on then
        cmdConns["noclip"]=RS.Stepped:Connect(function()
            local ch=LP.Character;if not ch then return end
            for _,p in ipairs(ch:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
        end)
    end
end

local function setFly(on,speed)
    flySpeed=speed or flySpeed;flyOn=on
    if flyConn then flyConn:Disconnect();flyConn=nil end
    local ch=LP.Character;if not ch then return end
    local hrp=ch:FindFirstChild("HumanoidRootPart");if not hrp then return end
    local bv=hrp:FindFirstChild("FlyVelocity");if bv then bv:Destroy() end
    if not on then
        local hum=getHum();if hum then hum.PlatformStand=false end
        return
    end
    local hum=getHum();if hum then hum.PlatformStand=true end
    local vel=Instance.new("BodyVelocity",hrp);vel.Name="FlyVelocity";vel.MaxForce=Vector3.new(1e5,1e5,1e5);vel.Velocity=Vector3.zero
    local bg=Instance.new("BodyGyro",hrp);bg.Name="FlyGyro";bg.MaxTorque=Vector3.new(1e5,1e5,1e5);bg.P=1e4
    flyConn=RS.RenderStepped:Connect(function()
        if not flyOn then return end
        local cf=Camera.CFrame;local dir=Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W) then dir=dir+cf.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then dir=dir-cf.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then dir=dir-cf.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then dir=dir+cf.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
        vel.Velocity=dir.Magnitude>0 and dir.Unit*flySpeed or Vector3.zero
        bg.CFrame=cf
    end)
end

local wsConn,jpConn=nil,nil
local function runCmd(raw,logFn)
    local parts={}
    for w in raw:lower():gmatch("%S+") do parts[#parts+1]=w end
    if #parts==0 then return end
    local cmd=parts[1];local loop=(parts[#parts]=="loop")
    local function log(msg) if logFn then logFn(msg) end end

    if cmd=="noclip" then
        setNoclip(not noclipOn);log("Noclip: "..(noclipOn and "ON" or "OFF"))
    elseif cmd=="fly" then
        local spd=tonumber(parts[2]) or flySpeed
        setFly(not flyOn,spd);log("Fly: "..(flyOn and "ON spd="..flySpeed or "OFF"))
    elseif cmd=="ws" or cmd=="walkspeed" then
        local val=tonumber(parts[2]) or 16
        stopCmd("ws")
        if loop then
            cmdConns["ws"]=RS.Stepped:Connect(function() local h=getHum();if h then h.WalkSpeed=val end end)
            log("WalkSpeed "..val.." loop ON")
        else
            local h=getHum();if h then h.WalkSpeed=val end;log("WalkSpeed -> "..val)
        end
    elseif cmd=="jp" or cmd=="jumppower" then
        local val=tonumber(parts[2]) or 50
        stopCmd("jp")
        if loop then
            cmdConns["jp"]=RS.Stepped:Connect(function() local h=getHum();if h then h.JumpPower=val end end)
            log("JumpPower "..val.." loop ON")
        else
            local h=getHum();if h then h.JumpPower=val end;log("JumpPower -> "..val)
        end
    elseif cmd=="stopws" then stopCmd("ws");log("WalkSpeed loop stopped")
    elseif cmd=="stopjp" then stopCmd("jp");log("JumpPower loop stopped")
    elseif cmd=="stopfly" then setFly(false);log("Fly OFF")
    elseif cmd=="stopnoclip" then setNoclip(false);log("Noclip OFF")
    elseif cmd=="god" then
        local h=getHum();if h then h.MaxHealth=math.huge;h.Health=math.huge end;log("God mode ON")
    elseif cmd=="resetws" then stopCmd("ws");local h=getHum();if h then h.WalkSpeed=16 end;log("WalkSpeed reset")
    elseif cmd=="resetjp" then stopCmd("jp");local h=getHum();if h then h.JumpPower=50 end;log("JumpPower reset")
    elseif cmd=="tp" then
        local hrp=getHRP();if hrp and tonumber(parts[2]) and tonumber(parts[3]) and tonumber(parts[4]) then hrp.CFrame=CFrame.new(tonumber(parts[2]),tonumber(parts[3]),tonumber(parts[4]));log("Teleported") end
    else
        log("Unknown: "..cmd)
    end
end

