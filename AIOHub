local Camera = workspace.CurrentCamera
local fovCircle -- SG circle drawn on screen

local function makeFovCircle()
    local old=LP.PlayerGui:FindFirstChild("ESP_FOV"); if old then old:Destroy() end
    if not C.aimOn then return end
    local sg=Instance.new("ScreenGui",LP.PlayerGui); sg.Name="ESP_FOV"; sg.ResetOnSpawn=false; sg.IgnoreGuiInset=true; sg.DisplayOrder=99
    local sz=C.aimFov*4  -- pixels: fov 1=4px, fov 100=400px
    local frame=Instance.new("Frame",sg)
    frame.Size=UDim2.new(0,sz,0,sz); frame.AnchorPoint=Vector2.new(.5,.5); frame.Position=UDim2.new(.5,0,.5,0)
    frame.BackgroundTransparency=1; frame.BorderSizePixel=0
    Instance.new("UICorner",frame).CornerRadius=UDim.new(1,0)
    local stroke=Instance.new("UIStroke",frame); stroke.Color=Color3.fromRGB(255,255,255); stroke.Thickness=1.2; stroke.Transparency=0.4
    fovCircle=frame
end

local function getScreenCenter()
    local vp=Camera.ViewportSize; return Vector2.new(vp.X/2,vp.Y/2)
end

local function worldToScreen(pos)
    local sp,vis=Camera:WorldToScreenPoint(pos)
    return Vector2.new(sp.X,sp.Y), vis, sp.Z
end

local function updAim()
    if not C.aimOn then return end
    local center=getScreenCenter()
    local fovPx=C.aimFov*4/2  -- radius in pixels
    local bestDist=math.huge
    local bestHRP=nil

    -- Collect candidates
    local candidates={}
    if C.aimPlayer then
        for _,pl in ipairs(PL:GetPlayers()) do
            if pl==LP then continue end
            local ch=pl.Character
            local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
            local hum=ch and ch:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health>0 then candidates[#candidates+1]=hrp end
        end
    end
    if C.aimEntity then
        for inst,v in pairs(eC2) do
            if not v or not inst.Parent then continue end
            local p=inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart")
            if p then candidates[#candidates+1]=p end
        end
    end

    for _,hrp in ipairs(candidates) do
        local sp,vis=worldToScreen(hrp.Position)
        if not vis then continue end
        local screenDist=(sp-center).Magnitude
        if screenDist<fovPx and screenDist<bestDist then
            bestDist=screenDist; bestHRP=hrp
        end
    end

    if bestHRP then
        local cam=Camera
        local dir=(bestHRP.Position-cam.CFrame.Position).Unit
        cam.CFrame=CFrame.new(cam.CFrame.Position,cam.CFrame.Position+dir)
    end
end

