-- Updates ESP
local function updP()
    local act={}
    for _,pl in ipairs(PL:GetPlayers()) do
        if pl==LP then continue end
        local ch=pl.Character; local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
        if not hrp then if ch then rmESP(ch) end; continue end
        act[ch]=true; local d=dst(hrp.Position)
        if C.player and C.on and d<=C.maxD then
            addHL(ch,C.pC); if C.hitbox then addHB(ch) else rmHB(ch) end
            if C.info then local hum=ch:FindFirstChildOfClass("Humanoid"); local bd=addBB(ch,pl.DisplayName,C.pC); if bd then bd.dl.Text=hum and string.format("%s %.0f/%.0f  %dm",bar(hum.Health,hum.MaxHealth),hum.Health,hum.MaxHealth,d) or string.format("%dm",d) end end
        else rmESP(ch) end
    end
    clean(function(i) return i:IsA("Model") and not act[i] and not isPC(i) and not i.Parent end)
end
local function updE()
    local sc={}
    for inst,v in pairs(eC2) do
        if not v or not inst.Parent then continue end
        local p=inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart"); if not p then continue end
        sc[inst]=true; local d=dst(p.Position)
        if C.entity and C.on and d<=C.maxD then
            addHL(inst,C.eC); if C.hitbox then addHB(inst) else rmHB(inst) end
            if C.info then local hum=inst:FindFirstChildOfClass("Humanoid"); local hp=hum and hum.Health or inst:GetAttribute("Health") or inst:GetAttribute("HP"); local mhp=hum and hum.MaxHealth or inst:GetAttribute("MaxHealth") or hp; local bd=addBB(inst,inst.Name,C.eC); if bd then bd.dl.Text=(hp and mhp and mhp>0) and string.format("%s %.0f/%.0f  %dm",bar(hp,mhp),hp,mhp,d) or string.format("%dm",d) end end
        else rmESP(inst) end
    end
    clean(function(i) return i:IsA("Model") and not isPC(i) and not sc[i] and not i.Parent end)
end
local function updO()
    local sc={}
    for inst,lbl in pairs(oC2) do
        if not inst.Parent then continue end; local p=root(inst); if not p then continue end
        sc[inst]=true; local d=dst(p.Position)
        if C.object and C.on and d<=C.maxD then
            addHL(inst:IsA("Model") and inst or p,C.oC); if C.hitbox then addHB(inst) else rmHB(inst) end
            if C.info then local bd=addBB(inst,inst.Name,C.oC); if bd then bd.dl.Text=string.format("%s  %dm",lbl,d) end end
        else rmESP(inst); rmESP(p) end
    end
    clean(function(i) return not sc[i] and not i.Parent end)
end

